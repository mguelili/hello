<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Always Keep Smiling 🌸</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    overflow:hidden;
    background:linear-gradient(135deg,#FFEAF4,#FFF8FC,#FDFDFD);
}

/* Floating background flowers */
.bgFlower{
    position:absolute;
    font-size:25px;
    animation:floating linear infinite;
    opacity:.25;
    pointer-events:none;
}

@keyframes floating{
    from{
        transform:translateY(110vh) rotate(0deg);
    }
    to{
        transform:translateY(-120vh) rotate(360deg);
    }
}

.card{
    width:90%;
    max-width:720px;
    background:rgba(255,255,255,.92);
    backdrop-filter:blur(12px);
    border-radius:30px;
    padding:45px;
    text-align:center;
    box-shadow:0 20px 50px rgba(255,105,180,.2);
    z-index:2;
}

h1{
    color:#ff4f8b;
    font-size:3rem;
    margin-bottom:20px;
}

p{
    color:#555;
    line-height:1.9;
    font-size:1.15rem;
}

button{
    margin-top:35px;
    padding:15px 40px;
    border:none;
    border-radius:50px;
    cursor:pointer;
    background:#ff4f8b;
    color:white;
    font-size:18px;
    transition:.3s;
}

button:hover{
    transform:scale(1.08);
    background:#ff2e74;
}

#quote{
    margin-top:30px;
    color:#ff2e74;
    font-size:1.3rem;
    font-weight:600;
    min-height:40px;
}

/* Flower Explosion */

.flower{
    position:fixed;
    left:50%;
    top:50%;
    transform:translate(-50%,-50%);
    pointer-events:none;
    animation:explode 2.2s ease-out forwards;
    z-index:9999;
}

@keyframes explode{

0%{
transform:translate(-50%,-50%) scale(.2);
opacity:1;
}

100%{
transform:
translate(calc(-50% + var(--x)),
calc(-50% + var(--y)))
rotate(720deg)
scale(1.8);

opacity:0;
}

}
</style>

</head>

<body>

<div class="card">

<h1>🌸 Always Keep Smiling 🌸</h1>

<p>
Hi! 😊
<br><br>
I just wanted to remind you of something...

<br><br>

No matter what happens,
I hope you always keep smiling.

Your smile has a way of making everything feel a little brighter.
Even on difficult days,
don't forget how wonderful you are.

Keep being yourself,
because that's more than enough.

💖
</p>

<button onclick="flowerExplosion()">
Next 🌸
</button>

<div id="quote"></div>

</div>

<script>

/* Background Flowers */

const backgroundFlowers=["🌸","🌺","🌷","🌼","🪷"];

function createBackgroundFlower(){

const flower=document.createElement("div");

flower.className="bgFlower";

flower.innerHTML=
backgroundFlowers[Math.floor(Math.random()*backgroundFlowers.length)];

flower.style.left=Math.random()*100+"vw";

flower.style.fontSize=(15+Math.random()*30)+"px";

flower.style.animationDuration=(10+Math.random()*10)+"s";

document.body.appendChild(flower);

setTimeout(()=>{
flower.remove();
},20000);

}

setInterval(createBackgroundFlower,700);

/* Messages */

const messages=[

"🌸 Your smile is beautiful. Never lose it.",

"💖 I hope today gives you another reason to smile.",

"🌷 Keep smiling—it suits you perfectly.",

"🌼 The world becomes brighter when you smile.",

"🌺 You're wonderful just the way you are.",

"🩷 Never forget how special you are.",

"✨ Keep shining and keep smiling.",

"🌸 You deserve every happiness in the world.",

"😊 I hope this little page made you smile.",

"💐 Keep smiling, because your smile is contagious."

];

/* Explosion */

function flowerExplosion(){

const flowers=[
"🌸","🌺","🌷","🌼","🪷","💐","🌹"
];

for(let i=0;i<180;i++){

const flower=document.createElement("div");

flower.className="flower";

flower.innerHTML=
flowers[Math.floor(Math.random()*flowers.length)];

flower.style.fontSize=
(18+Math.random()*35)+"px";

const angle=Math.random()*Math.PI*2;

const distance=250+Math.random()*500;

flower.style.setProperty("--x",
Math.cos(angle)*distance+"px");

flower.style.setProperty("--y",
Math.sin(angle)*distance+"px");

document.body.appendChild(flower);

setTimeout(()=>{
flower.remove();
},2200);

}

/* Random Message */

setTimeout(()=>{

const random=Math.floor(Math.random()*messages.length);

document.getElementById("quote").innerHTML=
messages[random];

},600);

}

</script>

</body>
</html>
